{
  "geode": "5.3.0",
  "gd": {
    "win": "2.2081",
    "android": "2.2081",
    "mac": "2.2081",
    "ios": "2.2081"
  },
  "id": "zhulis.blitzkrieg",
  "name": "Blitzkrieg",
  "version": "v2.0.1",
  "developer": "Zhulis",
  "description": "Blitzkrieg progression",
  "tags": [
    "gameplay",
    "interface",
    "enhancement",
    "offline"
  ],
  "dependencies": {
    "cvolton.level-id-api": "v2.0.0",
    "geode.node-ids": ">=v1.23.0"
  },
  "links": {
    "homepage": "https://dgkr-community.vercel.app/blitzkrieg",
    "community": "https://discord.gg/duuG4RqJKh"
  },
  "resources": {
    "sprites": [
      "resources/logo-circle.png",
      "resources/sprites/*.png",
      "resources/sprites/range/*.png"
    ],
    "spritesheets": {
      "Borders": [
        "resources/sprites/borders/*.png"
      ],
      "Buttons": [
        "resources/sprites/buttons/*.png"
      ]
    },
    "files": [
      "resources/audio/progress_complete.mp3",
      "resources/audio/stage_complete.mp3"
    ],
    "fonts": {
      "PusabFull": {
        "path": "resources/fonts/PusabFull.ttf",
        "size": 64,
        "charset": "32-500,8226,1040-1103"
      }
    }
  },
  "settings": {
    "gameplay-settings": {
      "type": "title",
      "name": "Gameplay"
    },
    "ignore-practice-mode": {
      "type": "bool",
      "name": "Ignore Practice Mode",
      "default": false
    },
    "ui-settings": {
      "type": "title",
      "name": "Interface"
    },
    "replace-practice-bar-with-blitzkrieg": {
      "type": "bool",
      "name": "Display Blitzkrieg stats instead of practice bar",
      "default": true
    },
    "practice-bar-divisions-color": {
      "name": "Color of stage divisions in progression",
      "type": "color",
      "default": "#ffffff"
    },
    "practice-bar-divisions-transparency": {
      "name": "Transparency of stage divisions in progression",
      "type": "float",
      "default": 0.4,
      "min": 0.1,
      "max": 1,
      "control": {
        "slider": true
      }
    },
    "practice-bar-stages-fill-color": {
      "name": "Stage progression fill color",
      "type": "color",
      "default": "#ff0052"
    },
    "practice-bar-ranges-fill-color": {
      "name": "Run progression fill color",
      "type": "color",
      "default": "#ffc8cf"
    },
    "disable-progress-expansion-animation": {
      "type": "bool",
      "name": "Disable progress expansion statistics animation",
      "default": false
    },
    "expand-progress-by-default": {
      "type": "bool",
      "name": "Expand progress details by default",
      "default": true
    },
    "notifications-settings": {
      "type": "title",
      "name": "Notifications"
    },
    "disable-run-notifications": {
      "type": "bool",
      "name": "Disable run notifications",
      "default": false
    },
    "disable-run-notification-sound": {
      "type": "bool",
      "name": "Disable run notification sound",
      "default": false
    },
    "sfx-settings": {
      "type": "title",
      "name": "SFX"
    },
    "sfx-use-custom-sounds": {
      "name": "Use Custom SFX's",
      "type": "bool",
      "default": false,
      "description": "Use custom sounds for the SFX's!"
    },
    "sfx-progress-path": {
      "name": "Progress-Pass SFX",
      "type": "file",
      "description": "Path for the Progress-Pass sound effect.",
      "enable-if": "sfx-use-custom-sounds",
      "default": {
        "android": "",
        "mac": "",
        "win": "",
        "ios": ""
      },
      "control": {
        "dialog": "open",
        "filters": [
          {
            "files": [
              "*.mp3",
              "*.ogg"
            ],
            "description": "Sound Files"
          }
        ]
      }
    },
    "sfx-stage-path": {
      "name": "Stage-Pass SFX",
      "type": "file",
      "description": "Path for the Stage-Pass sound effect.",
      "enable-if": "sfx-use-custom-sounds",
      "default": {
        "android": "",
        "mac": "",
        "win": "",
        "ios": ""
      },
      "control": {
        "dialog": "open",
        "filters": [
          {
            "files": [
              "*.mp3",
              "*.ogg"
            ],
            "description": "Sound Files"
          }
        ]
      }
    }
  }
}