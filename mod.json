{
  "geode": "5.3.0",
  "gd": {
    "win": "2.2081",
    "android": "2.2081",
    "mac": "2.2081",
    "ios": "2.2081"
  },
  "id": "zhulis.blitzkrieg",
  "name": "Blitzkrieg",
  "version": "v2.1.0",
  "developer": "Zhulis",
  "description": "Blitzkrieg progression",
  "tags": [
    "gameplay",
    "interface",
    "performance",
    "enhancement",
    "offline"
  ],
  "dependencies": {
    "cvolton.level-id-api": "v2.0.0",
    "geode.node-ids": ">=v1.23.0"
  },
  "links": {
    "homepage": "https://dgkr-community.vercel.app/blitzkrieg",
    "community": "https://discord.gg/duuG4RqJKh"
  },
  "resources": {
    "sprites": [
      "resources/logo-circle.png",
      "resources/sprites/*.png",
      "resources/sprites/range/*.png"
    ],
    "spritesheets": {
      "Borders": [
        "resources/sprites/borders/*.png"
      ],
      "Buttons": [
        "resources/sprites/buttons/*.png"
      ]
    },
    "files": [
      "resources/audio/progress_complete.mp3",
      "resources/audio/stage_complete.mp3"
    ]
  },
  "settings": {
    "gameplay-settings": {
      "type": "title",
      "name": "Gameplay"
    },
    "ignore-practice-mode": {
      "type": "bool",
      "name": "Ignore Practice Mode",
      "default": false
    },
    "ui-settings": {
      "type": "title",
      "name": "Interface"
    },
    "expand-progress-by-default": {
      "type": "bool",
      "name": "Auto-expand progress details",
      "description": "Automatically expand progress details in the stage browser.",
      "default": true
    },
    "disable-progress-expansion-animation": {
      "type": "bool",
      "name": "Disable expansion animation",
      "description": "Disable the animation when progress statistics expand.",
      "default": false
    },
    "replace-practice-bar-with-blitzkrieg": {
      "type": "bool",
      "name": "Blitzkrieg instead of practice bar",
      "description": "Display Blitzkrieg statistics instead of the practice progress bar.",
      "default": true
    },
    "practice-bar-divisions-color": {
      "type": "color",
      "name": "Practice stage divider color",
      "description": "Color of the stage division markers in the progression bar.",
      "default": "#ffffff",
      "enable-if": "replace-practice-bar-with-blitzkrieg"
    },
    "practice-bar-stages-fill-color": {
      "name": "Stage progression fill color",
      "type": "color",
      "default": "#ff0052",
      "enable-if": "replace-practice-bar-with-blitzkrieg"
    },
    "practice-bar-ranges-fill-color": {
      "name": "Run progression fill color",
      "type": "color",
      "default": "#ffc8cf",
      "enable-if": "replace-practice-bar-with-blitzkrieg"
    },
    "practice-bar-divisions-transparency": {
      "type": "float",
      "name": "Stage divider opacity",
      "description": "Transparency of stage divisions in the progression bar.",
      "default": 0.4,
      "min": 0.1,
      "max": 1,
      "enable-if": "replace-practice-bar-with-blitzkrieg",
      "control": {
        "slider": true,
        "slider-step": 0.1,
        "arrow-step": 0.1
      }
    },
    "streamer-mode": {
      "type": "title",
      "name": "Streamer mode"
    },
    "enable-streamer-mode": {
      "type": "bool",
      "name": "Enable streamer mode",
      "description": "Streamer mode hides profile names, leaving only the first letter. You can hide more information in the settings",
      "default": false
    },
    "notifications-settings": {
      "type": "title",
      "name": "Notifications"
    },
    "disable-run-notifications": {
      "type": "bool",
      "name": "Disable run notifications",
      "default": false
    },
    "disable-run-notification-sound": {
      "type": "bool",
      "name": "Disable run notification sound",
      "default": false
    },
    "sfx-settings": {
      "type": "title",
      "name": "SFX"
    },
    "ignore-built-in-game-sfx": {
      "name": "Ignore the game's built-in sfx",
      "type": "bool",
      "default": false
    },
    "sfx-volume": {
      "name": "SFX volume",
      "type": "float",
      "default": 1,
      "min": 0,
      "max": 1,
      "control": {
        "slider": true,
        "slider-step": 0.1,
        "arrow-step": 0.1
      }
    },
    "sfx-use-custom-sounds": {
      "name": "Use Custom SFX's",
      "type": "bool",
      "default": false,
      "description": "Use custom sounds for the SFX's!"
    },
    "sfx-progress-path": {
      "name": "Progress-Pass SFX",
      "type": "file",
      "description": "Path for the Progress-Pass sound effect.",
      "enable-if": "sfx-use-custom-sounds",
      "default": {
        "android": "",
        "mac": "",
        "win": "",
        "ios": ""
      },
      "control": {
        "dialog": "open",
        "filters": [
          {
            "files": [
              "*.mp3",
              "*.ogg"
            ],
            "description": "Sound Files"
          }
        ]
      }
    },
    "sfx-stage-path": {
      "name": "Stage-Pass SFX",
      "type": "file",
      "description": "Path for the Stage-Pass sound effect.",
      "enable-if": "sfx-use-custom-sounds",
      "default": {
        "android": "",
        "mac": "",
        "win": "",
        "ios": ""
      },
      "control": {
        "dialog": "open",
        "filters": [
          {
            "files": [
              "*.mp3",
              "*.ogg"
            ],
            "description": "Sound Files"
          }
        ]
      }
    },
    "keybinds": {
      "type": "title",
      "name": "Keybinds"
    },
    "next-stage-keybind": {
      "type": "keybind",
      "name": "Switch to the next stage",
      "default": [
        "D",
        "E"
      ]
    },
    "prev-stage-keybind": {
      "type": "keybind",
      "name": "Switch to the previous stage",
      "default": [
        "A",
        "Q"
      ]
    }
  }
}